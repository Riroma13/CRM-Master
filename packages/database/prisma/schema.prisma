generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Multi-tenant ───────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  slug      String   @unique
  name      String
  logo      String?
  config    Json?    @default("{}")
  isActive                Boolean  @default(true) @map("is_active")
  plan                    String   @default("gratuito") // gratuito | profesional | empresa
  planDesde               DateTime? @map("plan_desde")
  betterAuthOrganizationId String?  @unique @map("better_auth_org_id")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  activityEvents ActivityEvent[]
  searchEntries    SearchEntry[]
  automationRules  AutomationRule[]
  tenantSecrets    TenantSecret[]
  users            User[]
  clients         Cliente[]
  sistemas        Sistema[]
  items    ItemInventario[]
  eventos  EventoBitacora[]
  tareas   Tarea[]
  disponibilidad Disponibilidad?
  citas    Cita[]
  recursos Resource[]
  incidencias Incidencia[]
  presupuestos Presupuesto[]
  webhooks Webhook[]
  plantillas PlantillaDocumento[]
  pagos PagoIntent[]
  auditLogs AuditLog[]
  comunicaciones Comunicacion[]
  encuestas Encuesta[]
  eventosAcademicos EventoAcademico[]
  documentos Documento[]
  clientUsers ClientUser[]

  @@map("tenants")
}

// ─── Better-Auth tables ──────────────────────────────────────────────
// These models are managed by Better-Auth for authentication and
// organization-based authorization. Our existing Tenant maps to
// organization via betterAuthOrganizationId, and our User links to
// betterAuthUserId for session validation.
//
// Naming follows Better-Auth's expected model names to keep the
// Prisma adapter configuration minimal.

model organization {
  id        String           @id @default(uuid())
  name      String
  slug      String?          @unique
  logo      String?
  createdAt DateTime         @default(now())
  metadata  Json?

  members   member[]
  invitations invitation[]

  @@map("ba_organizations")
}

model member {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  userId         String       @map("user_id")
  role           String       @default("member")
  createdAt      DateTime     @default(now())

  organization  organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user          user          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("ba_members")
}

model invitation {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  email          String
  role           String       @default("member")
  status         String       @default("pending")
  inviterId      String       @map("inviter_id")
  createdAt      DateTime     @default(now())

  organization   organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("ba_invitations")
}

model user {
  id            String    @id @default(uuid())
  email         String    @unique
  emailVerified Boolean   @default(false)
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions   session[]
  accounts   account[]
  members    member[]

  @@map("ba_users")
}

model session {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ba_sessions")
}

model account {
  id              String  @id @default(uuid())
  userId          String  @map("user_id")
  accountId       String  @map("account_id")
  providerId      String  @map("provider_id")
  accessToken     String? @map("access_token")
  refreshToken    String? @map("refresh_token")
  idToken         String? @map("id_token")
  accessTokenExpiresAt DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope           String?
  password        String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user user @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ba_accounts")
}

model verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("ba_verifications")
}

// ─── Auth / Users (legacy, for business logic) ──────────────────────

model User {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  email           String   @unique
  name            String?
  role            String   @default("user") // "superadmin" | "admin" | "user"
  passwordHash    String?  @map("password_hash")
  notifEmail      Boolean  @default(true) @map("notif_email")
  notifWhatsApp   Boolean  @default(false) @map("notif_whatsapp")
  avatar          String?
  isActive        Boolean  @default(true) @map("is_active")
  betterAuthUserId String? @unique @map("better_auth_user_id") // links to ba_users.id
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("users")
}

// ─── Cliente ────────────────────────────────────────────────────────

model Cliente {
  id               String   @id @default(uuid())
  tenantId         String   @map("tenant_id")
  nombre           String
  tipoNegocio      String?  @map("tipo_negocio")
  contactoPrincipal String? @map("contacto_principal")
  estadoRelacion   String   @default("Activo") @map("estado_relacion")
  saludGeneral     String   @default("🟢") @map("salud_general")
  fechaInicio      DateTime? @map("fecha_inicio")
  notasGenerales   String?  @map("notas_generales")
  tags             String[]
  customFields     Json?    @default("{}") @map("custom_fields")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  sistemas    Sistema[]
  tareas      Tarea[]
  incidencias Incidencia[]
  presupuestos Presupuesto[]
  clientUsers ClientUser[]

  @@index([tenantId])
  @@map("clientes")
}

// ─── ClientUser ──────────────────────────────────────────────────────

model ClientUser {
  id           String   @id @default(cuid())
  clienteId    String
  tenantId     String
  email        String   @unique
  passwordHash String
  nombre       String?
  telefono     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, email])
  @@map("client_users")
}

model Presupuesto {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  clienteId   String   @map("cliente_id")
  titulo      String
  lineas      Json     @default("[]")  // [{concepto, cantidad, precioUnitario, total}]
  total       Float    @default(0)
  estado      String   @default("borrador") // borrador | enviado | aceptado | rechazado
  notas       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  cliente Cliente @relation(fields: [clienteId], references: [id])
  pagos PagoIntent[]

  @@index([tenantId])
  @@index([clienteId])
  @@map("presupuestos")
}

model Webhook {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  url       String
  eventos   String[] // eventos que activan este webhook
  isActive  Boolean  @default(true) @map("is_active")
  ultimoEnvio DateTime? @map("ultimo_envio")
  ultimoError String?  @map("ultimo_error")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("webhooks")
}

// ─── Sistema ────────────────────────────────────────────────────────

model Sistema {
  id                String    @id @default(uuid())
  tenantId          String    @map("tenant_id")
  clienteId         String    @map("cliente_id")
  nombreSistema     String    @map("nombre_sistema")
  tipo              String
  entorno           String?
  version           String?
  estadoTecnico     String    @default("🟢") @map("estado_tecnico")
  fechaUltimoChequeo DateTime? @map("fecha_ultimo_chequeo")
  credencialesRef   String?   @map("credenciales_ref")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant  Tenant           @relation(fields: [tenantId], references: [id])
  cliente Cliente          @relation(fields: [clienteId], references: [id], onDelete: Cascade)
  items   ItemInventario[]
  eventos EventoBitacora[]
  tareas  Tarea[]

  @@index([tenantId])
  @@index([clienteId])
  @@map("sistemas")
}

// ─── ItemInventario ─────────────────────────────────────────────────

model ItemInventario {
  id                 String   @id @default(uuid())
  tenantId           String   @map("tenant_id")
  sistemaId          String   @map("sistema_id")
  categoria          String
  nombre             String
  estado             String   @default("Implementado")
  descripcion        String?
  fechaImplementacion DateTime? @map("fecha_implementacion")
  responsable        String?

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  sistema Sistema @relation(fields: [sistemaId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sistemaId])
  @@map("items_inventario")
}

// ─── EventoBitacora ─────────────────────────────────────────────────

model EventoBitacora {
  id             String   @id @default(uuid())
  tenantId       String   @map("tenant_id")
  sistemaId      String   @map("sistema_id")
  fecha          DateTime @default(now())
  tipo           String
  titulo         String
  descripcion    String?
  siguienteAccion String? @map("siguiente_accion")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  sistema Sistema @relation(fields: [sistemaId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([sistemaId])
  @@index([fecha])
  @@map("eventos_bitacora")
}

// ─── Tarea ──────────────────────────────────────────────────────────

model Tarea {
  id          String    @id @default(uuid())
  tenantId    String    @map("tenant_id")
  clienteId   String?   @map("cliente_id")
  sistemaId   String?   @map("sistema_id")
  titulo      String
  estado      String    @default("Pendiente")
  prioridad   String    @default("Media")
  fechaLimite DateTime? @map("fecha_limite")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  cliente Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  sistema Sistema? @relation(fields: [sistemaId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([clienteId])
  @@index([sistemaId])
  @@map("tareas")
}

// ─── Documentos ──────────────────────────────────────────────────────

model Documento {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  clienteId   String?  @map("cliente_id")
  filename    String
  storageKey  String   @unique @map("storage_key")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  category    String   @default("general")
  description String?
  isDeleted   Boolean  @default(false) @map("is_deleted")
  uploadedBy  String   @map("uploaded_by")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant    @relation(fields: [tenantId], references: [id])
  shares ShareLink[]

  @@index([tenantId])
  @@index([category])
  @@map("documentos")
}

model ShareLink {
  id            String   @id @default(uuid())
  documentoId   String   @map("documento_id")
  token         String   @unique
  expiresAt     DateTime @map("expires_at")
  maxDownloads  Int?     @map("max_downloads")
  downloadCount Int      @default(0) @map("download_count")
  createdBy     String   @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")

  documento Documento @relation(fields: [documentoId], references: [id], onDelete: Cascade)

  @@index([token])
  @@map("share_links")
}

// ─── Citas / Disponibilidad ──────────────────────────────────────────

model Disponibilidad {
  id            String   @id @default(uuid())
  tenantId      String   @unique @map("tenant_id")
  timezone      String   @default("Europe/Madrid")
  slotDuration  Int      @default(30) @map("slot_duration")
  minNotice     Int      @default(240) @map("min_notice")
  maxDays       Int      @default(30) @map("max_days")
  dailySchedule Json     @default("[{\"day\":1,\"start\":\"09:00\",\"end\":\"14:00\"},{\"day\":1,\"start\":\"16:00\",\"end\":\"19:00\"},{\"day\":2,\"start\":\"09:00\",\"end\":\"14:00\"},{\"day\":3,\"start\":\"09:00\",\"end\":\"14:00\"},{\"day\":4,\"start\":\"09:00\",\"end\":\"14:00\"},{\"day\":5,\"start\":\"09:00\",\"end\":\"14:00\"}]") @map("daily_schedule")
  blockedDates  Json?    @default("[]") @map("blocked_dates")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("disponibilidad")
}

model Resource {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  nombre      String
  tipo        String   @default("professional") // professional | space | equipment
  descripcion String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  citas  Cita[]

  @@index([tenantId])
  @@map("recursos")
}

model Incidencia {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  clienteId   String?  @map("cliente_id")
  titulo      String
  descripcion String?
  estado      String   @default("abierta") // abierta | en_curso | resuelta | cerrada
  prioridad   String   @default("media")   // baja | media | alta | critica
  asignadoA   String?  @map("asignado_a")
  fechaLimite DateTime? @map("fecha_limite")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  cliente Cliente? @relation(fields: [clienteId], references: [id])

  @@index([tenantId])
  @@index([tenantId, estado])
  @@index([clienteId])
  @@map("incidencias")
}

model Cita {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  clienteId       String?  @map("cliente_id")
  resourceId      String?  @map("resource_id")
  titulo          String   @default("Consulta")
  descripcion     String?
  fecha           DateTime
  duracion        Int      @default(30)
  estado          String   @default("pendiente")
  clienteNombre   String?  @map("cliente_nombre")
  clienteEmail    String?  @map("cliente_email")
  clienteTelefono String?  @map("cliente_telefono")
  notasInternas   String?  @map("notas_internas")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  resource Resource? @relation(fields: [resourceId], references: [id])

  @@index([tenantId])
  @@index([fecha])
  @@index([tenantId, estado])
  @@index([resourceId])
  @@map("citas")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  tenantId   String   @map("tenant_id")
  userId     String?  @map("user_id")
  userEmail  String?  @map("user_email")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  details    String?
  ip         String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId], map: "audit_log_tenant")
  @@index([createdAt], map: "audit_log_created")
  @@map("audit_log")
}

model Comunicacion {
  id          Int      @id @default(autoincrement())
  tenantId    String   @map("tenant_id")
  clienteId   String   @map("cliente_id")
  tipo        String   // llamada | email | reunion | otro
  titulo      String
  descripcion String?
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([clienteId])
  @@map("comunicaciones")
}

model PlantillaDocumento {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  nombre      String
  tipo        String   @default("documento") // documento | contrato | presupuesto
  contenido   String   // HTML con variables {{...}}
  variables   Json     @default("[]")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("plantillas_documentos")
}

model PagoIntent {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  clienteId     String?  @map("cliente_id")
  presupuestoId String?  @map("presupuesto_id")
  monto         Float
  moneda        String   @default("eur")
  metodoPago    String?  @map("metodo_pago") // stripe | transferencia | efectivo
  estado        String   @default("pendiente") // pendiente | completado | fallido | reembolsado
  referencia    String?  // ID de transacción externa (Stripe)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  presupuesto Presupuesto? @relation(fields: [presupuestoId], references: [id])

  @@index([tenantId])
  @@map("pagos")
}

// ─── ActivityEvent (Activity Timeline) ──────────────────────────────

model ActivityEvent {
  id           Int      @id @default(autoincrement())
  tenantId     String   @map("tenant_id")
  clienteId    String?  @map("cliente_id")
  entityType   String   @map("entity_type")
  entityId     String?  @map("entity_id")
  eventType    String   @map("event_type")
  actor        String
  sourceModule String   @map("source_module")
  severity     String   @default("info")
  category     String
  payload      Json     @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")

  eventId       String?  @unique @map("event_id")
  correlationId String?  @map("correlation_id")
  causationId   String?  @map("causation_id")
  visibility    String   @default("tenant-only")
  subjectName   String?  @map("subject_name")
  actorName     String?  @map("actor_name")
  searchVector  Unsupported("tsvector")? @map("search_vector")
  enriched      Boolean  @default(false)
  enrichedAt    DateTime? @map("enriched_at")
  occurredAt    DateTime? @map("occurred_at")
  receivedAt    DateTime @default(now()) @map("received_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt(sort: Desc)], map: "timeline_tenant_created")
  @@index([tenantId, clienteId, createdAt(sort: Desc)], map: "timeline_cliente")
  @@index([tenantId, entityType, entityId, createdAt(sort: Desc)], map: "timeline_entity")
  @@index([tenantId, eventType, createdAt(sort: Desc)], map: "timeline_event_type")
  @@index([tenantId, sourceModule, createdAt(sort: Desc)], map: "timeline_source_module")
  @@index([tenantId, severity, createdAt(sort: Desc)], map: "timeline_severity")
  @@index([tenantId, correlationId], map: "timeline_correlation")
  @@index([searchVector], type: Gin, map: "timeline_search_vector")
  @@map("activity_events")
}

model Encuesta {
  id          Int      @id @default(autoincrement())
  tenantId    String   @map("tenant_id")
  referenciaId String  @map("referencia_id") // cita_id o incidencia_id
  tipo        String   // cita | incidencia
  puntuacion  Int      // 1-5
  comentario  String?
  respondida  Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("encuestas")
}

model EventoAcademico {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  titulo      String
  tipo        String   // festivo | examen | evento | periodo_notas
  fechaInicio DateTime @map("fecha_inicio")
  fechaFin    DateTime? @map("fecha_fin")
  descripcion String?
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("eventos_academicos")
}

// ─── SearchEntry (Universal Search) ──────────────────────────────────

model SearchEntry {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  clienteId   String?  @map("cliente_id")
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  title       String
  description String?
  tags        String[]
  searchVector String?  @map("search_vector") @db.Text
  payload     Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([entityType, entityId, tenantId])
  @@index([tenantId, entityType])
  @@map("search_entries")
}

// ─── TenantSecrets (encrypted credentials) ──────────────────────────

model TenantSecret {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  key       String
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, key])
  @@map("tenant_secrets")
}

// ─── Automation Hub ─────────────────────────────────────────────────

model AutomationRule {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  name        String
  description String?
  trigger     String
  actions     String[]
  filters     Json?    @default("{}")
  config      Json?    @default("{}")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  executions AutomationExecution[] @relation("ruleExecutions")

  @@index([tenantId, trigger])
  @@map("automation_rules")
}

model AutomationExecution {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  ruleId        String   @map("rule_id")
  trigger       String
  status        String   @default("pending")
  actionsTotal  Int      @map("actions_total")
