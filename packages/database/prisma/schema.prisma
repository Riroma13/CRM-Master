//
// pgvector extension required: CREATE EXTENSION IF NOT EXISTS vector;
// HNSW index on embedding: CREATE INDEX ON kb_chunks USING hnsw (embedding vector_cosine_ops)
// Embedding model: all-MiniLM-L6-v2 (384-dim) via @xenova/transformers

model KbChunk {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
