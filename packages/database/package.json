{
  "name": "@crm-master/database",
  "version": "0.0.1",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "prisma generate && pnpm generate:scope",
    "generate:scope": "tsx prisma/generators/tenant-scope/generator.ts",
    "generate:scope:verify": "tsx prisma/generators/tenant-scope/generator.ts --verify",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:scope": "vitest run prisma/generators/tenant-scope/generated/tenant-scope.spec.ts",
    "db:seed": "ts-node src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prisma": "^6.0.0",
    "ts-node": "^10.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
