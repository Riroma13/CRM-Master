{
  "moduleFileExtensions": ["js", "json", "ts", "mjs"],
  "rootDir": ".",
  "testRegex": "test/(doorbell|e2e)/.*spec\\.ts$",
  "transform": {
    "^.+\\.([jt]s|mjs)$": ["ts-jest", { "diagnostics": false }]
  },
  "testEnvironment": "node",
  "testTimeout": 30000,
  "transformIgnorePatterns": [],
  "moduleNameMapper": {
    "^@crm-master/database$": "<rootDir>/../../packages/database/src"
  }
}
